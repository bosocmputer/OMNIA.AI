# OMNIA.AI Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/omniadb"

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://HOST:6379"

# ─── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="your-64-char-hex-secret-here"

# 32-character AES-256 encryption key for agent souls
AGENT_ENCRYPT_KEY="your-32-char-key-padded-to-32-ch"

# ─── OpenRouter (AI) ───────────────────────────────────────
OPENROUTER_API_KEY="sk-or-..."

# ─── App ───────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
HOSTNAME="localhost"

# ─── Optional: Google OAuth (Phase 2) ─────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Optional: Stripe (Phase 3) ───────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
